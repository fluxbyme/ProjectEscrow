{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "../..",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "src/**/*.ts",
    "../../contracts/escrow/build/Escrow/Escrow_Escrow.ts",
    "../../contracts/escrow/build/JettonEscrow/JettonEscrow_JettonEscrow.ts"
  ]
}
